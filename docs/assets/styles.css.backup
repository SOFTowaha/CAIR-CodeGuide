/* ===== Content Area ===== */
.content {
    padding: 3rem;
    max-width: 900px;
    margin: 0 auto;
}

.loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 400px;
    gap: 1rem;
}

