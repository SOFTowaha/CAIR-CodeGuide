/* ===== Main Container ===== */
.main-container {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr var(--toc-width);
    margin-top: var(--header-height);
    min-height: calc(100vh - var(--header-height));
}

/* ===== Sidebar ===== */
